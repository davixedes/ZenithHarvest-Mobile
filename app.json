{
  "expo": {
    "name": "Zenith Harvest",
    "slug": "ZenithApp",
    "version": "1.0.0",
    "scheme": "zenithapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zenith.harvest"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D9E75",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.zenith.harvest"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Zenith Harvest to access your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zenith Harvest to access your photos.",
          "cameraPermission": "Allow Zenith Harvest to use your camera."
        }
      ],
      "expo-font",
      "expo-splash-screen",
      [
        "react-native-maps",
        {
          "googleMapsApiKey": ""
        }
      ]
    ]
  }
}
